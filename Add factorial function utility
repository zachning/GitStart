# factorial.py

def factorial(n):
    """
    Calculate the factorial of a non-negative integer n.
    Returns 1 if n is 0.
    """
    if n < 0:
        raise ValueError("Input must be a non-negative integer")
    result = 1
    for i in range(1, n + 1):
        result *= i
    return result


# Example usage
if __name__ == "__main__":
    print(f"Factorial of 5 is {factorial(5)}")
